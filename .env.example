# KONACH client environment template (manual MySQL/AppServ setup)
# Install MySQL manually using AppServ, then configure values below.

MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=your_password

MYSQL_HOST=localhost
MYSQL_PORT=3306

DB_HOST=localhost
DB_PORT=3306
DB_NAME=konach
DB_USER=konach_user
DB_PASSWORD=strong_password

KONACH_DEFAULT_ADMIN_USER=admin
KONACH_DEFAULT_ADMIN_PASS=CHANGE_ME_APP_ADMIN_PASSWORD

DB_BACKUP_DIR=backups/database
DB_BACKUP_RETENTION_COUNT=5
DB_BACKUP_ENABLED=1
MYSQLDUMP_PATH=

# Optional if config/license_public_key.pem is shipped with the app.
# Accepts any of:
# 1) Full PEM public key text (single line with \n escapes)
# 2) Base64 raw 32-byte Ed25519 public key
# 3) Base64 DER/SPKI Ed25519 public key
KONACH_LICENSE_PUBLIC_KEY_PEM=REPLACE_WITH_PUBLIC_KEY

KONACH_APP_VERSION=1.0.0
KONACH_LICENSE_DIR=
