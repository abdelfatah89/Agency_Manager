             <string notr="true">QFrame#cashBoxCard { background-color: #FFFFFF; border: 1px solid rgba(220,212,200,0.60); border-radius: 14px; }

QLineEdit {
    color: #2c343f;               /* Professional dark charcoal text */
    font-family: &quot;Arial&quot;; 
    font-size: 14px;
    font-weight: 500;
    background-color: #ffffff;    /* Solid white for contrast */
    border-radius: 7px;
    border: 1px solid #E5E7EB;    /* Light grey neutral border */
    padding: 5px 10px;            /* Comfortable internal spacing */
    qproperty-alignment: 'AlignCenter';
}

/* Hover State */
QLineEdit:hover {
    border: 1px solid #00ab84;    /* Emerald green highlight */
    background-color: #f0fdf4;    /* Very soft mint tint */
}

/* Focus State (Active Typing) */
QLineEdit:focus {
    border: 2px solid #00ab84;    /* Bold emerald border */
    background-color: #ffffff;    /* Clear white for typing */
}

/* Disabled/Read-Only State */
QLineEdit:disabled {
    background-color: #f9fafb;
    color: #9ca3af;
    border: 1px solid #e5e7eb;
}

QLabel {
    color: #1E293B; /* Color from image analysis */
    font-family: 'Tajawal';
    font-size: 11pt;
    font-weight: 500;
    qproperty-alignment: 'AlignCenter';
	padding-left: 5px;
}</string>
