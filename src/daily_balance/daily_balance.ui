                    <property name="styleSheet">
                     <string notr="true">QLineEdit {
    color: #2c343f;               /* Professional dark charcoal text */
    font-family: &quot;Arial&quot;; 
    font-size: 14px;
    font-weight: 500;
    background-color: #ffffff;    /* Solid white for contrast */
    border-radius: 7px;
    border: 1px solid #E5E7EB;    /* Light grey neutral border */
    padding: 5px 10px;            /* Comfortable internal spacing */
    qproperty-alignment: 'AlignCenter';
}

/* Hover State */
QLineEdit:hover {
    border: 1px solid #FACC15;    /* Soft gold border on hover */
    background-color: #fff8c2;    /* Your main color: Light yellow tint */
}

/* Focus State (Active Typing) */
QLineEdit:focus {
    border: 2px solid #CA8A04;    /* Deeper amber border for high visibility */
    background-color: #ffffff;    /* Clear white for typing */
}

/* Disabled/Read-Only State */
QLineEdit:disabled {
    background-color: #F9FAFB;
    color: #9CA3AF;
    border: 1px solid #E5E7EB;
}</string>
