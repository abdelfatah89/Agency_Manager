                  </property>
                  <property name="styleSheet">
                   <string notr="true">/* The Main Container Frame */
QFrame#totalFrame_2 {
    background-color: #fef2f2; /* Light Amber background */
    border: 1px solid #fecaca; /* Slightly darker amber border */
    border-radius: 12px;       /* Rounded corners as seen in the image */
    padding: 5px 10px;
}

/* The Title Label (e.g., &quot;المجموع المدفوعات OUT&quot;) */
QLabel#lbl_totaltitle2 {
    color: #b91c1c;           /* Dark Brown/Amber text */
    font-family: 'Tajawal';   /* Primary Arabic font from your files */
    font-size: 15px;
    font-weight: 600;
    background: transparent;
    qproperty-alignment: 'AlignCenter';
}

/* The Numerical Value Label (e.g., &quot;106852.18&quot;) */
QLabel#lbl_totalval {
    color: #78350F;           /* Deep Chocolate Brown */
    font-family: 'Liberation Mono'; /* Monospaced font for aligned numbers */
    font-size: 20px;
    font-weight: 800;         /* Extra bold for emphasis */
    background: transparent;
    qproperty-alignment: 'AlignCenter';
}

/* The Container Frame */
QFrame#cpRemaining1Frame {
    background-color: #fff1f2;
    border: 2px solid #fecdd3;
    border-radius: 15px;
    padding: 7px;
}

/* The Value Label */
QLabel {
    color: #be123c; /* Rose Crimson */
    font-weight: 500;
    qproperty-alignment: 'AlignCenter';
}</string>
