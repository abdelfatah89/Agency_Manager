               <property name="styleSheet">
                <string notr="true">QFrame#cbTotalFrame { background: qlineargradient(x1:0,y1:0,x2:1,y2:0,stop:0 #059669,stop:1 #10B981); border: none; border-radius: 10px; }

/* The Container Box */
QFrame#cbTotalFrame {
    background-color: #e9f5f0; /* Very light mint background */
    border: 1px solid #c2e2d5;   /* Subtle light green border */
    border-radius: 20px;         /* Rounded corners */
    padding: 7px;
}

/* The &quot;Grand Total&quot; Arabic Text */
QLabel#lbl_cbTotal {
    color: #10B981;              /* Primary green color */
    font-family: &quot;Tajawal&quot;; 
    font-size: 20px;
    font-weight: bold;
    background: transparent;
}

/* The Numerical Value */
QLabel#cbTotalVal {
    color: #10B981;              /* Primary green color */
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 30px;             /* Larger size for the amount */
    font-weight: 800;            /* Extra Bold */
    background: transparent;
}</string>
