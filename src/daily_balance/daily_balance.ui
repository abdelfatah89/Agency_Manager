                <property name="styleSheet">
                 <string notr="true">/* Base Style: Mimicking n_piece_editline */
QDateEdit {
    background-color: transparent;
    border: none;
    border-radius: 8px;
    /*padding: 6px 10px;*/
    font: 500 10pt &quot;Overpass&quot;;
    color: #374151;
}

/* Interaction States */
QDateEdit:hover {
    border-color: #d1d5db;
}

QDateEdit:focus {
    border-color: #1d7ae2;
}

/* Hiding the Spin/Drop-down Buttons via QSS */
QDateEdit::drop-down {
    width: 0px;
    border: none;
    background: transparent;
}

QDateEdit::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
}

/* Read-Only State (Matching your previous EditLine style) */
QDateEdit[readOnly=&quot;true&quot;] {
    background-color: #f9fafb;
    color: #9ca3af;
    border: 1px solid #f3f4f6;
}

/* Disabled State */
QDateEdit:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
    border: 1px solid #e2e8f0;
}</string>
