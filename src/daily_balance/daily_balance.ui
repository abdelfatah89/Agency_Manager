           <widget class="QFrame" name="generalCard">
            <property name="styleSheet">
             <string notr="true">QFrame#generalCard { background-color: #FFFFFF; border: 1px solid rgba(220,212,200,0.60); border-radius: 14px; }

QLineEdit {
    color: #2c343f;               
    font-family: &quot;Overpass&quot;; 
    font-size: 14px;
    font-weight: 500;
    background-color: #ffffff;    
    border-radius: 7px;
    border: 1px solid #E5E7EB;    
    padding: 5px 10px;            
}

/* Hover State - Soft Blue Glow */
QLineEdit:hover {
    border: 1px solid #3B82F6;    /* Primary Blue border */
    background-color: #eff6ff;    /* Extremely light blue wash (Blue-50) */
}

/* Focus State - Active Typing */
QLineEdit:focus {
    border: 2px solid #3B82F6;    /* Thicker blue border */
    background-color: #ffffff;    
    outline: none;                
}

/* Disabled State */
QLineEdit:disabled {
    background-color: #f8fafc;    /* Very light slate/grey */
    color: #94a3b8;
    border: 1px solid #e2e8f0;
}

/* Read-Only State (Added for consistency with your previous requests) */
QLineEdit[readOnly=&quot;true&quot;] {
    background-color: #f1f5f9;
    color: #64748b;
    border: 1px solid #e2e8f0;
}

QLabel {
    color: #1E293B; /* Color from image analysis */
    font-family: 'Tajawal';
    font-size: 11pt;
    font-weight: 500;
    qproperty-alignment: 'AlignCenter';
	padding-left: 5px;
	color: #1E293B;
}</string>
