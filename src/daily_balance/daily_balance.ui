            <property name="styleSheet">
             <string notr="true">QFrame#cashPlusCard { background-color: #FFFFFF; border: 1px solid rgba(220,212,200,0.60); border-radius: 14px; }

QLineEdit {
    color: #2c343f;               /* Keep the high-contrast dark text */
    font-family: &quot;Arial&quot;; 
    font-size: 14px;
    font-weight: 500;
    background-color: #ffffff;    /* Pure white background */
    border-radius: 7px;
    border: 1px solid #E5E7EB;    /* Soft neutral border */
    padding: 5px 10px;            /* Increased padding for a more modern feel */
}

/* Hover State */
QLineEdit:hover {
    border: 1px solid #F59E0B;    /* Amber border on hover */
    background-color: #fffbeb;    /* Extremely light amber tint */
}

/* Focus State */
QLineEdit:focus {
    border: 2px solid #F59E0B;    /* Thicker amber border when active */
    background-color: #ffffff;    /* Return to white background for typing clarity */
    outline: none;                /* Removes default OS focus glow */
}

/* Disabled State (Optional but recommended) */
QLineEdit:disabled {
    background-color: #f3f4f6;
    color: #9ca3af;
    border: 1px solid #e5e7eb;
}

QLabel {
    color: #1E293B; /* Color from image analysis */
    font-family: 'Tajawal';
    font-size: 11pt;
    font-weight: 500;
    qproperty-alignment: 'AlignCenter';
	padding-left: 5px;
	color: #1E293B;
}</string>
