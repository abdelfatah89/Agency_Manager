                    <property name="styleSheet">
                     <string notr="true">QToolButton {
    /* Background and Border */
    background-color: #DBEAFE; /* Light blue background (from Tailwind blue-100) */
    border: none;
    border-radius: 15px;       /* High radius for the pill/oval shape */
    
    /* Padding and Size */
    padding: 10px;
    min-width: 30px;
    min-height: 15px;
}

QToolButton:hover {
    background-color: #BFDBFE; /* Slightly darker blue on hover (blue-200) */
}

QToolButton:pressed {
    background-color: #93C5FD; /* Even deeper blue when clicked (blue-300) */
}

/* Icon Styling */
/* Note: Qt handles the icon color via the QIcon file itself, 
   but you can adjust the padding for the icon here. */
QToolButton::menu-indicator {
    image: none;               /* Removes the small arrow if it has a menu */
}</string>
