                  <property name="styleSheet">
                   <string notr="true">/* The Main Container Frame */
QFrame#cpRemaining1Frame {
    background-color: #FEF3C7; /* Light Amber background */
    border: 1px solid #FDE68A; /* Slightly darker amber border */
    border-radius: 12px;       /* Rounded corners as seen in the image */
    padding: 5px 10px;
}

/* The Title Label (e.g., &quot;المجموع المدفوعات OUT&quot;) */
QLabel#lbl_cpRemaining1 {
    color: #92400E;           /* Dark Brown/Amber text */
    font-family: 'Tajawal';   /* Primary Arabic font from your files */
    font-size: 15px;
    font-weight: 600;
    background: transparent;
    qproperty-alignment: 'AlignCenter';
}

/* The Numerical Value Label (e.g., &quot;106852.18&quot;) */
QLabel#cpRemaining1Val {
    color: #78350F;           /* Deep Chocolate Brown */
    font-family: 'Liberation Mono'; /* Monospaced font for aligned numbers */
    font-size: 20px;
    font-weight: 800;         /* Extra bold for emphasis */
    background: transparent;
    qproperty-alignment: 'AlignCenter';
}</string>
