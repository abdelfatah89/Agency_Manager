             <property name="styleSheet">
              <string notr="true">QTableWidget#Table_clients {
    background-color: transparent;
    border: none;
    gridline-color: rgba(243, 244, 246, 0.90);
	font-family: &quot;Tajawal&quot;;
    alternate-background-color: rgba(255, 255, 255, 0.22);
    outline: none;
}
QTableWidget#Table_clients::item {
    padding: 10px 20px;
    color: #4B5563;
    border-bottom: 1px solid #E5E7EB;
	min-height: 50px;
}
QTableWidget#Table_clients::item:hover { background-color: rgba(239, 246, 255, 0.55); }
QTableWidget#Table_clients::item:selected { background-color: #DBEAFE; color: #1E40AF; }
QHeaderView::section {
    background-color: rgba(255, 197, 21, 0.25);
    color: #374151;
	font-family: &quot;Tajawal&quot;;
    font-size: 12px;
    font-weight: 600;
    padding: 12px 20px;
    border: none;
    border-bottom: 1px solid #E5E7EB;
    text-transform: uppercase;
    letter-spacing: 0px;
}</string>
