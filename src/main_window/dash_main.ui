           <property name="styleSheet">
            <string notr="true">/* Base State */
QToolButton#BackupBtn {
    background-color: #EFF6FF;    /* Very light blue wash (Blue-50) */
    color: #3B82F6;               /* Primary Blue text */
    border: none;
    border-radius: 20px;          /* Matches the pill shape of logout */
    padding: 5px;
}

/* Hover State: Becomes more vivid blue */
QToolButton#BackupBtn:hover {
    background-color: #DBEAFE;    /* Light blue (Blue-100) */
    color: #2563EB;               /* Deeper blue text */
}

/* Pressed State: Tactile feedback */
QToolButton#BackupBtn:pressed {
    background-color: #BFDBFE;    /* Medium blue (Blue-200) for click feedback */
    padding-top: 10px;            /* Subtle physical sink effect */
    padding-bottom: 6px;
}

/* Disabled State: Neutral look */
QToolButton#BackupBtn:disabled {
    background-color: #F9FAFB;    /* Neutral grey-ish wash */
    color: #D1D5DB;               /* Faded grey text */
}
</string>
