           <property name="styleSheet">
            <string notr="true">/* Base State */
QToolButton#UserManagerBtn {
    background-color: #EEF2FF;    /* Very light Indigo wash */
    color: #6366F1;               /* Primary Indigo text */
    border: none;
    border-radius: 20px;          /* Pill shape */
    padding: 5px;
    font-weight: 600;
}

/* Hover State */
QToolButton#UserManagerBtn:hover {
    background-color: #E0E7FF;    /* Deeper Indigo wash */
    color: #4F46E5;               /* Richer Indigo text */
}

/* Pressed State */
QToolButton#UserManagerBtn:pressed {
    background-color: #C7D2FE;    /* Medium Indigo for click */
    padding-top: 10px;            /* Tactile sink effect */
    padding-bottom: 6px;
}

/* Disabled State */
QToolButton#UserManagerBtn:disabled {
    background-color: #F9FAFB;    /* Neutral grey wash */
    color: #D1D5DB;               /* Faded grey text */
}</string>
