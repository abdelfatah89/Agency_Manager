           <property name="styleSheet">
            <string notr="true">/* Base State */
QToolButton#InfoBtn {
    background-color: #F1F5F9;    /* Soft Slate wash */
    color: #475569;               /* Slate Grey-Blue text */
    border: none;
    border-radius: 20px;          /* Pill shape */
    padding: 5px;
    font-weight: 600;
}

/* Hover State */
QToolButton#InfoBtn:hover {
    background-color: #E2E8F0;    /* Slightly deeper slate */
    color: #1E293B;               /* Darker navy-slate text */
}

/* Pressed State */
QToolButton#InfoBtn:pressed {
    background-color: #CBD5E1;    /* Click feedback */
    padding-top: 10px;            /* Tactile sink effect */
    padding-bottom: 6px;
}

/* Disabled State */
QToolButton#InfoBtn:disabled {
    background-color: #F9FAFB;    /* Neutral grey wash */
    color: #D1D5DB;               /* Faded grey text */
}</string>
