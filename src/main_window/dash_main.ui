           <property name="styleSheet">
            <string notr="true">/* Base State */
QToolButton#logoutBtn {
    background-color: #FEF2F2;    /* Very light rose/red wash */
    color: #EF4444;               /* Primary Red text */
    border: none;
    border-radius: 20px;          /* Pill shape (adjust based on height) */
}

/* Hover State: Background becomes slightly more vivid */
QToolButton#logoutBtn:hover {
    background-color: #FEE2E2;    /* Slightly deeper rose */
    color: #DC2626;               /* Deeper red text */
}

/* Pressed State: Tactile &quot;click&quot; effect */
QToolButton#logoutBtn:pressed {
    background-color: #FECACA;    /* Darkest rose wash for click feedback */

}

/* Disabled State: Faded look */
QToolButton#logoutBtn:disabled {
    background-color: #F9FAFB;    /* Neutral grey-ish wash */
    color: #D1D5DB;               /* Faded grey text */
}
</string>
