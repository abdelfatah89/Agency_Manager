                    <property name="styleSheet">
                     <string notr="true">QFrame#Frame_Btns {
	background-color: rgba(255, 255, 255, 110);
	border-radius: 25px;
	border: 1px solid rgb(176, 176, 176);

}

/* Base State: White card with light border */
QToolButton {
    background-color: #FFFFFF;
    border-radius: 14px;
    border: 1px solid #E5E7EB;
    padding: 30px 14px;
    text-align: right; /* Aligns Arabic text to the right */
    font-weight: 600;
    color: #4B5563; /* Slate grey for unselected text */
	spacing: 6px;
}

/* Hover State: Subtle grey wash */
QToolButton:hover {
    background-color: #F9FAFB;
    border-color: #D1D5DB;
    color: #111827; /* Darker text on hover */
}

/* Checked State: Dark Navy (Active Page) */
QToolButton:checked {
    background-color: #0F172A; /* Deep Navy from your Hero frame */
    color: #FFFFFF;            /* White text */
    border: none;
}

/* Pressed State: Tactile feedback when clicking */
QToolButton:pressed {
    background-color: #E5E7EB;
    padding: 30px 14px;
}

/* Disabled State: Faded out if a menu item is locked */
QToolButton:disabled {
    background-color: #F3F4F6;
    color: #9CA3AF;
    border: 1px solid #E5E7EB;
}

/* Specific styling for the Icon */
QToolButton::menu-indicator {
    image: none; /* Hide the default dropdown arrow */
}</string>
                    </property>
