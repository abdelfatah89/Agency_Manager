# KONACH production environment template (Windows)
# Copy this file to config/.env in the exported client_app folder and fill real values.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=konach_new
DB_USER=konach_app
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

KONACH_DEFAULT_ADMIN_USER=admin
KONACH_DEFAULT_ADMIN_PASS=REPLACE_WITH_STRONG_ADMIN_PASSWORD

DB_BACKUP_DIR=backups/database
DB_BACKUP_RETENTION_COUNT=7
DB_BACKUP_ENABLED=1
MYSQLDUMP_PATH=

# rclone cloud backup settings
DB_BACKUP_RCLONE_ENABLED=1
RCLONE_PATH=rclone/rclone.exe
DB_BACKUP_RCLONE_REMOTE=database_backup
DB_BACKUP_RCLONE_REMOTE_PATH=KONACH-Backups/database
DB_BACKUP_RCLONE_SOURCE_DIR=backups/database

# Optional if config/license_public_key.pem exists in release package.
# Supported values:
# 1) PEM public key text (single line with \n escapes)
# 2) Base64 raw 32-byte Ed25519 public key
# 3) Base64 DER/SPKI Ed25519 public key
KONACH_LICENSE_PUBLIC_KEY_PEM=REPLACE_WITH_PUBLIC_KEY_OR_LEAVE_EMPTY

KONACH_APP_VERSION=1.0.0
KONACH_LICENSE_DIR=
